# XylonStudio Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# DEPLOYMENT STAGE
# ==========================================
# Options: development, testing, demo, production
DEPLOYMENT_STAGE=development

# ==========================================
# LLM CONFIGURATION
# ==========================================

# Primary LLM Provider
# Options: claude, openai, ollama, vllm
LLM_PROVIDER=claude

# Fallback Provider (optional, for high availability)
# LLM_FALLBACK_PROVIDER=ollama

# Enable comparison mode (test multiple providers simultaneously)
LLM_COMPARE_MODE=false

# ==========================================
# CLAUDE CONFIGURATION (Development/Demo)
# ==========================================
ANTHROPIC_API_KEY=sk-ant-api03-xxx
CLAUDE_MODEL=claude-sonnet-4.6
# Options: claude-opus-4.6, claude-sonnet-4.6, claude-haiku-4.5

# ==========================================
# OPENAI CONFIGURATION (Alternative)
# ==========================================
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4-turbo
# OPENAI_BASE_URL=https://api.openai.com/v1

# ==========================================
# OLLAMA CONFIGURATION (Local Development/Testing)
# ==========================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:32b

# ==========================================
# vLLM CONFIGURATION (Production)
# ==========================================
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# ==========================================
# LLM GENERATION PARAMETERS
# ==========================================
LLM_MAX_TOKENS=4000
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9

# ==========================================
# DATABASE
# ==========================================
POSTGRES_USER=xylon
POSTGRES_PASSWORD=changeme
POSTGRES_DB=xylonstudio
DATABASE_URL=postgresql://xylon:changeme@localhost:5432/xylonstudio

# ==========================================
# REDIS
# ==========================================
REDIS_URL=redis://localhost:6379/0

# ==========================================
# MONITORING
# ==========================================
LOG_LEVEL=INFO
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=changeme

# ==========================================
# API SERVER
# ==========================================
API_HOST=0.0.0.0
API_PORT=5000
API_WORKERS=4

# ==========================================
# SECURITY
# ==========================================
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# ==========================================
# COST MONITORING
# ==========================================
# Alert when monthly cost exceeds threshold (USD)
COST_ALERT_THRESHOLD=100.0
# Email for cost alerts
# COST_ALERT_EMAIL=hello@xylonstud.io
